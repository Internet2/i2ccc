# Frontend Environment Configuration

# Environment mode: 'development' or 'production'
# In development: uses Vite proxy (/api/) to avoid CORS
# In production: uses direct proxy API endpoint
VITE_ENVIRONMENT=development

# Proxy API endpoint (get this from CDK output: ProxyAPIEndpoint)
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/prod/api/
# Note: The API key is now handled securely server-side by the proxy Lambda
# You no longer need to expose the API key in the frontend!
VITE_API_ENDPOINT=https://your-proxy-api-id.execute-api.us-east-1.amazonaws.com/prod/api/

# DEPRECATED: VITE_API_KEY is no longer needed with the secure proxy
# The proxy Lambda retrieves the API key from AWS Systems Manager Parameter Store
# VITE_API_KEY=<no-longer-needed>